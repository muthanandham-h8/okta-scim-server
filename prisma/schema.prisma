generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- SCIM resources ---------------------------------------------------

model ScimUser {
  id            String   @id @default(uuid())
  externalId    String?
  userName      String   @unique
  givenName     String?
  familyName    String?
  email         String?
  active        Boolean  @default(true)
  passwordHash  String?
  raw           Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  memberships   ScimGroupMember[]

  @@map("scim_users")
}

model ScimGroup {
  id          String   @id @default(uuid())
  externalId  String?
  displayName String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members     ScimGroupMember[]

  @@map("scim_groups")
}

model ScimGroupMember {
  id      String    @id @default(uuid())
  group   ScimGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  groupId String
  user    ScimUser  @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId  String

  @@unique([groupId, userId])
  @@map("scim_group_members")
}

// OAuth 2.0 tables were removed: Keycloak is now the authorization server and
// owns all client/token state. This service only validates Keycloak JWTs.
