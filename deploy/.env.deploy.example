# VM-side environment for the production compose files.
# Copy this to a file named `.env` in the REPO ROOT on the VM (next to the
# docker-compose.*.yml files), keep the section for the path you're using, then:
#
#   Caddy + DuckDNS:  docker compose -f docker-compose.caddy.yml up -d --build
#   ngrok:            docker compose -f docker-compose.prod.yml  up -d --build
#
# Only the variables below are read; every other setting (DATABASE_URL, JWKS
# URL, internal hostnames) is hard-wired to the compose network in the yml.

# ============================================================================
# OPTION A — Caddy + DuckDNS  (free, custom name, real Let's Encrypt TLS)
# Used by docker-compose.caddy.yml. This is the configured default.
# ============================================================================

# Public HTTPS URL Okta/Runscope reach. Chosen free DuckDNS name:
PUBLIC_BASE_URL=https://hash8-auth.duckdns.org
# Same host, WITHOUT the scheme (used for the Caddy site + X-Forwarded-Host):
PUBLIC_HOST=hash8-auth.duckdns.org

# DuckDNS auto-updater (keeps the A record pointed at this VM):
#   SUBDOMAIN is just the label, WITHOUT ".duckdns.org".
DUCKDNS_SUBDOMAIN=hash8-auth
#   TOKEN is shown at the top of https://www.duckdns.org after you sign in.
DUCKDNS_TOKEN=replace-with-your-duckdns-token

# ============================================================================
# OPTION B — ngrok  (free plan = random domain name; custom name needs paid)
# Used by docker-compose.prod.yml. Ignore this block if you're using Caddy.
# ============================================================================
# PUBLIC_BASE_URL=https://<your-ngrok-domain>.ngrok-free.dev
# PUBLIC_HOST=<your-ngrok-domain>.ngrok-free.dev
# NGROK_AUTHTOKEN=replace-with-your-ngrok-authtoken

# ============================================================================
# Shared
# ============================================================================
# Demo client secret shown on the /demo setup page. Must match the client in
# keycloak/realm-scim.json.
DEMO_CLIENT_SECRET=w_ZeIPDTrGvDwE9sb0fWQPXV-AZqmU-7
