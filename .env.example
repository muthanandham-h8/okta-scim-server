# Copy to .env (scripts/start.mjs does this automatically on first run).
# Local testing config (Keycloak is the authorization server; no Okta needed).

DATABASE_URL="postgresql://scim:scim@localhost:5434/okta_scim?schema=public"

# --- Public domain: THE single source of truth ------------------------------
# Everything derives from this: Keycloak KC_HOSTNAME, the edge-proxy host, ngrok
# --domain, and the app's SCIM "location" links + derived Keycloak issuer.
# Change it here (one line) and re-run the start script to propagate everywhere.
# NOTE: this reserved ngrok domain belongs to our team's ngrok account - use
# that account's authtoken (ngrok config add-authtoken <TOKEN>). Only one machine
# can serve a given reserved domain at a time. To use your own, put it here.
PUBLIC_BASE_URL="https://excluding-snowdrift-reformer.ngrok-free.dev"
PORT=3000

# --- Keycloak ---------------------------------------------------------------
# Realm name. The issuer is derived as ${PUBLIC_BASE_URL}/realms/${KEYCLOAK_REALM}
# so the domain lives only in PUBLIC_BASE_URL. Set KEYCLOAK_ISSUER to override.
KEYCLOAK_REALM="scim"
# JWKS fetched directly on localhost (same keys regardless of how KC is reached).
KEYCLOAK_JWKS_URI="http://localhost:8080/realms/scim/protocol/openid-connect/certs"
# Audience to require (optional). Blank = skip aud check.
KEYCLOAK_AUDIENCE=""
# Scope a caller must have to reach the SCIM API.
KEYCLOAK_REQUIRED_SCOPE="scim"

# --- OAuth client shown in the /demo setup guide ----------------------------
# Must match the client in keycloak/realm-scim.json (demo values).
DEMO_CLIENT_ID="scim-client"
DEMO_CLIENT_SECRET="w_ZeIPDTrGvDwE9sb0fWQPXV-AZqmU-7"
